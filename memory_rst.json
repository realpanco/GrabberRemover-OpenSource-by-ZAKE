  "rules": [
    {
      "id": "RST_001",
      "name": "Visual Studio PreBuild Event Injection",
      "regex": "<PreBuildEvent>[\\s\\S]*?<\\/PreBuildEvent>",
      "severity": "CRITICAL",
      "action": "REMOVE_BLOCK"
    },
    {
      "id": "RST_002",
      "name": "Visual Studio PostBuild Event Injection",
      "regex": "<PostBuildEvent>[\\s\\S]*?<\\/PostBuildEvent>",
      "severity": "CRITICAL",
      "action": "REMOVE_BLOCK"
    },
    {
      "id": "RST_003",
      "name": "PowerShell Hidden Execution / Dropper",
      "regex": "^.*(powershell|iwr|Invoke-WebRequest|DownloadString|Start-Process).*(-WindowStyle\\s+Hidden|-Enc|-EncodedCommand).*$",
      "severity": "CRITICAL",
      "action": "REMOVE_LINE"
    },
    {
      "id": "RST_004",
      "name": "Hexadecimal Obfuscated Command String",
      "regex": "^.*(\\\\x[0-9a-fA-F]{2}){15,}.*$",
      "severity": "HIGH",
      "action": "REMOVE_LINE"
    },
    {
      "id": "RST_005",
      "name": "Malicious System Execution Call",
      "regex": "^.*system\\s*\\(\\s*[a-zA-Z0-9_]+\\.c_str\\s*\\(\\s*\\)\\s*\\)\\s*;.*$",
      "severity": "HIGH",
      "action": "REMOVE_LINE"
    },
    {
      "id": "RST_006",
      "name": "Discord Webhook Exfiltration Endpoint",
      "regex": "https?:\\/\\/(ptb\\.|canary\\.)?discord(app)?\\.com\\/api\\/webhooks\\/[0-9]+\\/[a-zA-Z0-9_-]+",
      "severity": "CRITICAL",
      "action": "REPLACE_NULL"
    },
    {
      "id": "RST_007",
      "name": "Telegram Bot API Exfiltration URL",
      "regex": "https?:\\/\\/api\\.telegram\\.org\\/bot[0-9]+:[a-zA-Z0-9_-]+\\/sendMessage",
      "severity": "CRITICAL",
      "action": "REPLACE_NULL"
    },
    {
      "id": "RST_008",
      "name": "Browser LevelDB / Token Stealer Target",
      "regex": "^.*(Local State|Login Data|Google\\\\Chrome\\\\User Data|Cordova|leveldb|Token).*$",
      "severity": "MEDIUM",
      "action": "REMOVE_LINE"
    },
    {
      "id": "RST_009",
      "name": "WMI Shell Execution / Command Injection",
      "regex": "^.*(winmgmts|Win32_Process|CreateInstance|ExecMethod).*$",
      "severity": "HIGH",
      "action": "REMOVE_LINE"
    },
    {
      "id": "RST_010",
      "name": "Reflective DLL Injection / Shellcode Loader",
      "regex": "^.*(VirtualAllocEx|WriteProcessMemory|CreateRemoteThread|NtUnmapViewOfSection).*$",
      "severity": "CRITICAL",
      "action": "REMOVE_LINE"
    }
  ],
